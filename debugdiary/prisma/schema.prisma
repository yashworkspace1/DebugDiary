generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  password      String?
  plan          String    @default("free")
  createdAt     DateTime  @default(now())
  accounts      Account[]
  sessions      Session[]
  entries       Entry[]
  apiKeys       ApiKey[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Entry {
  id           String   @id @default(cuid())
  userId       String

  // Raw user input
  errorText    String
  fixText      String
  codeSnippet  String?
  context      String?  // project name or notes

  // AI enriched
  summary      String?
  whyItHappens String?
  language     String?
  framework    String?
  errorType    String?
  tags         String[]
  difficulty   String?  // "easy"|"medium"|"hard"
  aiEnriched   Boolean  @default(false)

  // Search embedding stored as JSON array
  // (pgvector not needed, use cosine similarity in JS)
  embedding    Json?

  // Meta
  source       String   @default("web")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model ApiKey {
  id        String    @id @default(cuid())
  userId    String
  key       String    @unique @default(cuid())
  label     String    @default("VS Code Extension")
  lastUsed  DateTime?
  createdAt DateTime  @default(now())
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
}
